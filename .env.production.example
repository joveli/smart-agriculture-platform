# Smart Agriculture Platform - Production Environment Variables
# Copy to .env and fill in real values

# Database
POSTGRES_USER=smartagri
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=smart_agriculture

# Redis
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_USER=smartagri
RABBITMQ_PASSWORD=change_me_in_production

# EMQX
EMQX_ADMIN=admin
EMQX_PASSWORD=change_me_in_production

# MinIO
MINIO_USER=smartagri
MINIO_PASSWORD=change_me_in_production

# Security
SECRET_KEY=generate_a_32_byte_random_string_here

# Application
CORS_ORIGINS=http://localhost,http://192.168.3.101

# MQTT
MQTT_BROKER_URL=mqtt://admin:public@emqx:1883
